# MCP Remote Agent - Configuration Example
# Copy this file to .env and customize

# Server ports
PORT=3100
WS_PORT=3101

# Authentication secrets (generate with: openssl rand -hex 24)
CLIENT_AUTH_SECRET=your_client_secret_here
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
JWT_SECRET=your_jwt_secret

# Domain configuration
DOMAIN=your-domain.com
SERVER_IP=1.2.3.4
