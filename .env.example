# MCP Remote Agent - Configuration Example
# Copy this file to .env and customize

# Server ports
PORT=3100
WS_PORT=3101

# Authentication secrets (generate with: openssl rand -hex 24)
CLIENT_AUTH_SECRET=your_client_secret_here
JWT_SECRET=your_jwt_secret

# OAuth 2.0 Configuration (for Claude.ai web connector)
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret

# API Key Authentication (for Claude Code CLI - recommended)
# Generate a new key with: node -e "const{randomBytes,createHash}=require('crypto');const k=randomBytes(32).toString('base64url');console.log('API_KEY='+k);console.log('API_KEY_HASH='+createHash('sha256').update(k).digest('hex'))"
# Store only the HASH here (never the plaintext key)
API_KEY_HASH=

# Domain configuration
DOMAIN=your-domain.com
SERVER_URL=https://your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
